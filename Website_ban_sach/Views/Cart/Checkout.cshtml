@model Website_ban_sach.Models.Order
@{
    ViewData["Title"] = "Thanh toán đơn hàng";
}

<style>
    .checkout-card {
        border: 1px solid #f3e8f5;
        border-radius: 12px;
        background-color: #fff;
    }
    .btn-checkout-confirm {
        background-color: #ff79c6;
        color: white;
        font-weight: bold;
        transition: background-color 0.2s;
    }
    .btn-checkout-confirm:hover {
        background-color: #e05ca7;
        color: white;
    }
    .form-control:focus {
        border-color: #ff79c6;
        box-shadow: 0 0 0 0.25rem rgba(255, 121, 198, 0.25);
    }
    .text-purple-main {
        color: #ff79c6 !important;
    }
    .payment-method-card {
        border: 2px solid #f3e8f5 !important;
        background-color: #fff;
        cursor: pointer;
        transition: all 0.2s ease-in-out;
    }
    .payment-method-card:hover {
        border-color: #ff79c6 !important;
        transform: translateY(-2px);
    }
    .payment-method-card:has(input[type="radio"]:checked) {
        border-color: #ff79c6 !important;
        background-color: #fff0f8 !important;
        box-shadow: 0 4px 12px rgba(255, 121, 198, 0.15);
    }
    .payment-method-card input[type="radio"]:checked ~ i {
        color: #ff79c6 !important;
    }
</style>

<div class="container my-5" style="min-height: 500px;">
    <h2 class="fw-bold mb-4 text-dark"><i class="fa-solid fa-credit-card me-2 text-purple-main"></i> Thanh toán đơn hàng</h2>

    <div class="row g-4">
        <!-- Cột nhập thông tin giao hàng -->
        <div class="col-lg-7">
            <div class="card checkout-card shadow-sm p-4">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="fa-solid fa-truck me-2 text-purple-main"></i> Thông tin giao hàng</h5>
                
                <form asp-action="Checkout" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                    <div class="mb-3">
                        <label asp-for="ReceiverName" class="form-label fw-medium text-secondary small"></label>
                        <input asp-for="ReceiverName" class="form-control" placeholder="Nhập họ và tên người nhận..." />
                        <span asp-validation-for="ReceiverName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReceiverPhone" class="form-label fw-medium text-secondary small"></label>
                        <input asp-for="ReceiverPhone" class="form-control" placeholder="Nhập số điện thoại nhận hàng..." />
                        <span asp-validation-for="ReceiverPhone" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ReceiverAddress" class="form-label fw-medium text-secondary small"></label>
                        <textarea asp-for="ReceiverAddress" rows="3" class="form-control" placeholder="Nhập đầy đủ địa chỉ giao hàng (số nhà, tên đường, phường/xã, quận/huyện...)..."></textarea>
                        <span asp-validation-for="ReceiverAddress" class="text-danger small"></span>
                    </div>

                    <!-- Lựa chọn phương thức thanh toán -->
                    <div class="mb-4">
                        <label class="form-label fw-medium text-secondary small">Phương thức thanh toán</label>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="payment-method-card text-center p-3 rounded-3 d-flex flex-column align-items-center justify-content-center h-100">
                                    <input type="radio" asp-for="PaymentMethod" value="COD" checked class="d-none" />
                                    <i class="fa-solid fa-truck-fast text-secondary fs-3 mb-2"></i>
                                    <span class="fw-bold text-dark small d-block">COD (Nhận hàng trả tiền)</span>
                                    <small class="text-muted text-center" style="font-size: 11px; max-width: 180px;">Thanh toán bằng tiền mặt khi giao hàng tận nơi</small>
                                </label>
                            </div>
                            <div class="col-md-6">
                                <label class="payment-method-card text-center p-3 rounded-3 d-flex flex-column align-items-center justify-content-center h-100">
                                    <input type="radio" asp-for="PaymentMethod" value="MOMO" class="d-none" />
                                    <i class="fa-solid fa-building-columns text-secondary fs-3 mb-2"></i>
                                    <span class="fw-bold text-dark small d-block">Thanh toán MoMo</span>
                                    <small class="text-muted text-center" style="font-size: 11px; max-width: 180px;">Quét mã QR VietQR chuyển khoản nhanh bằng điện thoại</small>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="PaymentMethod" class="text-danger small"></span>
                    </div>

                    <!-- Hướng dẫn / Thông báo nhanh -->
                    <div id="payment-note" class="alert alert-light border small text-secondary mb-4" style="background-color: #faf6fc;">
                        <i class="fa-solid fa-circle-info text-purple-main me-1"></i> Bạn sẽ thanh toán bằng tiền mặt trực tiếp cho nhân viên giao hàng khi nhận được sách.
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-checkout-confirm px-5 py-2.5 rounded-3 shadow-sm">
                            <i class="fa-solid fa-circle-check me-2"></i> Xác nhận đặt hàng
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2.5 rounded-3">
                            Quay lại giỏ hàng
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Cột tóm tắt giỏ hàng -->
        <div class="col-lg-5">
            <div class="card checkout-card shadow-sm p-4">
                <h5 class="fw-bold text-dark mb-3 border-bottom pb-2"><i class="fa-solid fa-basket-shopping me-2 text-purple-main"></i> Tóm tắt đơn hàng</h5>
                
                @{
                    var cartItems = ViewBag.CartItems as IEnumerable<Website_ban_sach.Models.CartItem> ?? new List<Website_ban_sach.Models.CartItem>();
                    decimal totalAmount = cartItems.Sum(item => item.TotalPrice);
                }

                <div class="mb-4" style="max-height: 250px; overflow-y: auto;">
                    @foreach (var item in cartItems)
                    {
                        <div class="d-flex align-items-center gap-3 py-2 border-bottom">
                            <img src="@item.ImageUrl" class="rounded border" style="width: 40px; height: 52px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=150'" />
                            <div class="flex-grow-1 min-w-0">
                                <span class="fw-bold text-dark d-block text-truncate small">@item.Title</span>
                                <small class="text-muted">Số lượng: @item.Quantity</small>
                            </div>
                            <span class="fw-semibold text-purple-main text-nowrap small">@item.TotalPrice.ToString("N0")đ</span>
                        </div>
                    }
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tạm tính:</span>
                    <span class="fw-medium">@totalAmount.ToString("N0")đ</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Phí vận chuyển:</span>
                    <span class="text-success small">Miễn phí</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between">
                    <span class="fw-bold text-dark fs-5">Tổng cộng:</span>
                    <span class="fw-bold text-purple-main fs-5">@totalAmount.ToString("N0")đ</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        $(document).ready(function () {
            $('input[name="PaymentMethod"]').change(function () {
                var selectedVal = $(this).val();
                if (selectedVal === 'COD') {
                    $('#payment-note').html('<i class="fa-solid fa-circle-info text-purple-main me-1"></i> Bạn sẽ thanh toán bằng tiền mặt trực tiếp cho nhân viên giao hàng khi nhận được sách.');
                } else if (selectedVal === 'MOMO'){
                        $('#payment-note').html('<i class="fa-solid fa-circle-info text-purple-main me-1"></i> Bạn sẽ được chuyển sang cổng thanh toán MoMo sau khi xác nhận đơn hàng.');
                }
            });
        });
    </script>
}
