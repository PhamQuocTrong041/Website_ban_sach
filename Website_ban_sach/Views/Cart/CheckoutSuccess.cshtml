@model Website_ban_sach.Models.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<style>
    .success-card {
        border: 1px solid #e1d5e7;
        border-radius: 16px;
        background-color: #fff;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.05);
    }
    .text-purple-main {
        color: #ff79c6 !important;
    }
    .bg-purple-main {
        background-color: #ff79c6 !important;
    }
    .bg-light-purple {
        background-color: #fff0f8 !important;
    }
    .border-purple-main {
        border-color: #ff79c6 !important;
    }
    .badge-status {
        font-size: 13px;
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 600;
    }
    .badge-unpaid {
        background-color: #fff3cd;
        color: #856404;
    }
    .badge-paid {
        background-color: #d4edda;
        color: #155724;
    }
    .qr-container {
        border: 2px dashed #ff79c6;
        border-radius: 12px;
        background-color: #fff;
        padding: 15px;
        max-width: 240px;
    }
    .btn-confirm-payment {
        background: linear-gradient(135deg, #ff79c6 0%, #e05ca7 100%);
        color: white;
        font-weight: 600;
        border: none;
        transition: all 0.3s ease;
    }
    .btn-confirm-payment:hover {
        background: linear-gradient(135deg, #e05ca7 0%, #c43d8b 100%);
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(255, 121, 198, 0.3);
    }
    .btn-home {
        border: 1px solid #ff79c6;
        color: #ff79c6;
        background: transparent;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-home:hover {
        background-color: #ff79c6;
        color: white;
    }
</style>

<div class="container my-5">
    <!-- Success Banner -->
    <div class="text-center mb-5">
        <div class="display-1 text-purple-main mb-3">
            <i class="fa-solid fa-circle-check animate__animated animate__bounceIn"></i>
        </div>
        <h1 class="fw-bold text-dark">Đặt hàng thành công!</h1>
        <p class="text-muted fs-5">Cảm ơn bạn đã mua sắm tại BookStore. Mã đơn hàng của bạn là <strong class="text-purple-main">#@Model.OrderCode</strong>.</p>
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success d-inline-block shadow-sm px-4 py-2 rounded-3 mt-2">
                <i class="fa-solid fa-bell me-2"></i> @TempData["SuccessMessage"]
            </div>
        }
    </div>

    <div class="row g-4">
        <!-- Cột thông tin chi tiết thanh toán / đơn hàng -->
        <div class="col-lg-7">
            <div class="card success-card p-4 h-100">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">
                    <i class="fa-solid fa-file-invoice me-2 text-purple-main"></i> Thông tin đơn hàng
                </h5>

                <div class="row g-3 mb-4">
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Ngày đặt hàng</small>
                        <span class="fw-semibold text-dark">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Phương thức thanh toán</small>
                        <span class="fw-semibold text-dark">
                            @if (Model.PaymentMethod == "COD")
                            {
                                <i class="fa-solid fa-truck-fast text-secondary me-1"></i> <span>COD (Thanh toán khi nhận hàng)</span>
                            }
                            else if (Model.PaymentMethod == "BankTransfer")
                            {
                                <i class="fa-solid fa-building-columns text-secondary me-1"></i> <span>Chuyển khoản ngân hàng</span>
                            }
                            else
                            {
                                <span>@Model.PaymentMethod</span>
                            }
                        </span>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Trạng thái thanh toán</small>
                        <span class="badge-status @(Model.PaymentStatus == "Đã thanh toán" ? "badge-paid" : "badge-unpaid") d-inline-block mt-1">
                            <i class="fa-solid @(Model.PaymentStatus == "Đã thanh toán" ? "fa-circle-check" : "fa-clock") me-1"></i>
                            @Model.PaymentStatus
                        </span>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Trạng thái đơn hàng</small>
                        <span class="badge-status badge-unpaid d-inline-block mt-1 text-dark bg-light border">
                            <i class="fa-solid fa-circle-notch fa-spin me-1 text-purple-main"></i> @Model.Status
                        </span>
                    </div>
                </div>

                <h5 class="fw-bold text-dark mb-3 border-bottom pb-2">
                    <i class="fa-solid fa-location-dot me-2 text-purple-main"></i> Thông tin người nhận
                </h5>
                <div class="mb-4">
                    <p class="mb-1"><strong>Họ và tên:</strong> @Model.ReceiverName</p>
                    <p class="mb-1"><strong>Số điện thoại:</strong> @Model.ReceiverPhone</p>
                    <p class="mb-0"><strong>Địa chỉ:</strong> @Model.ReceiverAddress</p>
                </div>

                <!-- Cấu hình chi tiết thanh toán theo phương thức -->
                <div class="mt-4 p-4 rounded-3 bg-light border">
                    @if (Model.PaymentMethod == "BankTransfer")
                    {
                        @if (Model.PaymentStatus == "Chưa thanh toán")
                        {
                            <div class="row align-items-center g-3">
                                <div class="col-md-7">
                                    <h6 class="fw-bold text-purple-main mb-3">
                                        <i class="fa-solid fa-qrcode me-1"></i> Hướng dẫn chuyển khoản VietQR
                                    </h6>
                                    <p class="small text-secondary mb-2">Vui lòng quét mã QR bên cạnh hoặc chuyển khoản theo thông tin tài khoản dưới đây:</p>
                                    <ul class="list-unstyled small text-dark mb-4">
                                        <li class="mb-1.5"><strong>Ngân hàng:</strong> MB Bank (Ngân hàng Quân Đội)</li>
                                        <li class="mb-1.5"><strong>Số tài khoản:</strong> <span class="text-purple-main fw-bold">123456789999</span></li>
                                        <li class="mb-1.5"><strong>Chủ tài khoản:</strong> NHOM 5 BOOKSTORE</li>
                                        <li class="mb-1.5"><strong>Số tiền:</strong> <span class="text-purple-main fw-bold">@Model.TotalAmount.ToString("N0")đ</span></li>
                                        <li class="mb-1.5"><strong>Nội dung:</strong> <span class="badge bg-purple-main fw-bold px-2 py-1">DH@Model.OrderCode</span></li>
                                    </ul>

                                    <form asp-action="ConfirmPayment" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <button type="submit" class="btn btn-confirm-payment w-100 py-2.5 rounded-3">
                                            <i class="fa-solid fa-circle-check me-2"></i> Xác nhận tôi đã chuyển khoản
                                        </button>
                                    </form>
                                </div>
                                <div class="col-md-5 text-center d-flex flex-column align-items-center justify-content-center">
                                    <div class="qr-container shadow-sm mb-2">
                                        <img src="https://img.vietqr.io/image/MB-123456789999-qr_only.png?amount=@Convert.ToInt64(Model.TotalAmount)&addInfo=DH@(Model.OrderCode)&accountName=NHOM%205%20BOOKSTORE" 
                                             class="img-fluid rounded" alt="VietQR Code" 
                                             onerror="this.src='https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=Chuyen%20khoan%20MBBank%20STK%20123456789999%20So%20tien%20@(Model.TotalAmount)%20Noi%20dung%20DH@(Model.OrderCode)'" />
                                    </div>
                                    <small class="text-muted" style="font-size: 11px;"><i class="fa-solid fa-scan me-1"></i> Mở ứng dụng Ngân hàng để quét</small>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-3">
                                <div class="text-success fs-3 mb-2"><i class="fa-solid fa-square-check"></i> Đã nhận thông tin thanh toán</div>
                                <p class="text-muted mb-0 small">Chúng tôi đã ghi nhận yêu cầu thanh toán chuyển khoản cho đơn hàng #@Model.OrderCode. Hệ thống đang tiến hành xử lý đơn hàng.</p>
                            </div>
                        }
                    }
                    else
                    {
                        <!-- COD -->
                        <div class="d-flex align-items-start gap-3">
                            <div class="fs-2 text-purple-main mt-1">
                                <i class="fa-solid fa-truck-fast"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold text-dark mb-2">Thanh toán COD khi nhận hàng</h6>
                                <p class="small text-secondary mb-0">Bạn vui lòng chuẩn bị số tiền mặt <strong class="text-purple-main">@Model.TotalAmount.ToString("N0")đ</strong>. Nhân viên giao hàng sẽ liên hệ với bạn trước khi phát hàng trong vòng 2-5 ngày làm việc.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Cột tóm tắt sản phẩm đã mua -->
        <div class="col-lg-5">
            <div class="card success-card p-4">
                <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">
                    <i class="fa-solid fa-basket-shopping me-2 text-purple-main"></i> Sản phẩm đã mua
                </h5>

                <div class="mb-4" style="max-height: 350px; overflow-y: auto;">
                    @foreach (var item in Model.OrderItems)
                    {
                        <div class="d-flex align-items-center gap-3 py-3 border-bottom">
                            <img src="@(item.Product?.ImageUrl)" class="rounded border" style="width: 50px; height: 68px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=150'" />
                            <div class="flex-grow-1 min-w-0">
                                <span class="fw-bold text-dark d-block text-truncate small">@(item.Product?.Title ?? "Sản phẩm")</span>
                                <small class="text-muted">Tác giả: @(item.Product?.Author ?? "Chưa rõ")</small>
                                <div class="d-flex justify-content-between align-items-center mt-1">
                                    <small class="text-secondary">Đơn giá: @item.Price.ToString("N0")đ</small>
                                    <small class="fw-medium text-dark">SL: @item.Quantity</small>
                                </div>
                            </div>
                            <span class="fw-semibold text-purple-main text-nowrap align-self-end small">@((item.Price * item.Quantity).ToString("N0"))đ</span>
                        </div>
                    }
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Tạm tính:</span>
                    <span class="fw-semibold small">@Model.TotalAmount.ToString("N0")đ</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Phí vận chuyển:</span>
                    <span class="text-success fw-medium small">Miễn phí</span>
                </div>
                <hr class="my-3">
                <div class="d-flex justify-content-between">
                    <span class="fw-bold text-dark fs-5">Tổng tiền thanh toán:</span>
                    <span class="fw-bold text-purple-main fs-5">@Model.TotalAmount.ToString("N0")đ</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Nút điều hướng -->
    <div class="text-center mt-5 d-flex justify-content-center gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-home px-4 py-2.5 rounded-3">
            <i class="fa-solid fa-house me-2"></i> Quay về trang chủ
        </a>
        <a asp-controller="Account" asp-action="Profile" class="btn btn-purple px-4 py-2.5 rounded-3">
            <i class="fa-solid fa-list-check me-2"></i> Xem lịch sử đơn hàng
        </a>
    </div>
</div>
