@model Website_ban_sach.Models.Product
@{
    ViewData["Title"] = Model.Title;
}
<style>
    .details-card {
        border: 1px solid #f3e8f5;
        background-color: #fff;
        border-radius: 16px;
    }

    .book-detail-img {
        max-height: 480px;
        width: 100%;
        object-fit: cover;
        border-radius: 12px;
    }

    .text-purple-main {
        color: #ff79c6 !important;
    }

    .bg-purple-main {
        background-color: #ff79c6 !important;
    }

    .btn-purple {
        background-color: #ff79c6;
        color: white;
        border: none;
        transition: background-color 0.2s;
    }

        .btn-purple:hover {
            background-color: #e05ca7;
            color: white;
        }

    .quantity-input {
        width: 70px;
        text-align: center;
        border: 1px solid #ced4da;
        border-radius: 4px;
    }
</style>

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="text-decoration-none text-purple-main">@(Model.Category?.Name ?? "Sách")</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>

    <div class="card details-card p-4 shadow-sm">
        <div class="row g-4">
            <div class="col-md-5">
                <img src="@Model.ImageUrl" class="book-detail-img shadow border" onerror="this.src='https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=500'" />
            </div>

            <div class="col-md-7 d-flex flex-column justify-content-between">
                <div>
                    <span class="badge bg-light text-dark border px-2.5 py-1.5 rounded-pill mb-2">
                        <i class="fa-solid fa-bookmark text-purple-main me-1"></i> @(Model.Category?.Name ?? "N/A")
                    </span>
                    <h1 class="fw-bold text-dark mb-2" style="font-size: 2.2rem;">@Model.Title</h1>
                    <h5 class="text-secondary mb-3">Tác giả: <strong class="text-dark">@Model.Author</strong></h5>

                    <div class="d-flex align-items-center gap-2 mb-4">
                        <div class="text-warning">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                    </div>

                    <hr class="text-muted">

                    <div class="my-4">
                        <div class="d-flex align-items-baseline gap-3">
                            <h2 class="text-purple-main fw-bold m-0" style="font-size: 2rem;">@Model.Price.ToString("N0")đ</h2>
                        </div>
                    </div>

                    <div class="mb-4">
                        <span class="fw-medium text-secondary">Tình trạng:</span>
                        @if (Model.StockQuantity > 0)
                        {
                            <span class="badge bg-success-subtle text-success px-2.5 py-1.5 ms-1">
                                <i class="fa-solid fa-circle-check me-1"></i> Còn hàng
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 ms-1">
                                <i class="fa-solid fa-circle-xmark me-1"></i> Hết hàng
                            </span>
                        }
                    </div>

                    <div class="mb-4">
                        <h6 class="fw-bold text-dark">Mô tả tóm tắt:</h6>
                        <p class="text-muted leading-relaxed" style="font-size: 15px;">
                            @(string.IsNullOrEmpty(Model.Description) ? "Thông tin mô tả về cuốn sách này đang được cập nhật thêm từ nhà xuất bản." : Model.Description)
                        </p>
                    </div>
                </div>

                <div class="border-top pt-4">
                    <div class="d-flex align-items-center flex-wrap gap-3">

                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex align-items-center gap-3 m-0">
                            <input type="hidden" name="id" value="@Model.Id" />

                            @if (Model.StockQuantity > 0)
                            {
                                <div class="d-flex align-items-center border rounded bg-light">
                                    <button type="button" class="btn btn-light border-0 py-2 px-3 fw-bold" onclick="changeQuantity(-1)">-</button>
                                    <input type="number" name="quantity" id="quantity" class="quantity-input border-0 py-2 bg-light" value="1" min="1" max="@Model.StockQuantity" readonly />
                                    <button type="button" class="btn btn-light border-0 py-2 px-3 fw-bold" onclick="changeQuantity(1)">+</button>
                                </div>
                                <button type="submit" class="btn btn-purple px-4 py-2.5 rounded-3 fw-bold shadow-sm d-flex align-items-center gap-2" style="height: 42px;">
                                    <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ hàng
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-secondary px-4 py-2.5 rounded-3 fw-bold disabled" style="height: 42px;">
                                    <i class="fa-solid fa-circle-xmark"></i> Hết hàng tạm thời
                                </button>
                            }
                        </form>

                        <form asp-controller="Wishlist" asp-action="AddToWishlist" method="post" class="m-0">
                            <input type="hidden" name="bookId" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger px-3 d-flex align-items-center justify-content-center"
                                    style="height: 42px; width: 45px; border-radius: 8px;" title="Thêm vào danh sách yêu thích">
                                <i class="fa-regular fa-heart fs-5"></i>
                            </button>
                        </form>

                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 py-2.5 rounded-3 d-flex align-items-center" style="height: 42px;">
                            Quay lại mua sắm
                        </a>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeQuantity(change) {
            var input = document.getElementById('quantity');
            if(input) {
                var currentVal = parseInt(input.value);
                var min = parseInt(input.min);
                var max = parseInt(input.max);
                var newVal = currentVal + change;
                if (newVal >= min && newVal <= max) {
                    input.value = newVal;
                }
            }
        }
    </script>
}