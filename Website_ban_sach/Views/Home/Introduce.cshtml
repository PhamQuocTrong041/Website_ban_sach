@{
    ViewData["Title"] = "Giới thiệu";
}

<style>
    /* Ô bự bọc toàn bộ nội dung */
    .super-intro-card {
        border: 1px solid #f3e8f5;
        background-color: #fff;
        border-radius: 20px; /* Bo góc bự siêu mượt */
        box-shadow: 0 10px 30px rgba(255, 121, 198, 0.1); /* Đổ bóng hồng nhẹ */
        padding: 60px 40px;
    }

    /* Icon sách bự ở trên đầu */
    .intro-icon-box {
        width: 80px;
        height: 80px;
        background-color: #fff0f8;
        color: #ff79c6;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin: 0 auto 25px;
    }

    /* Nút quay lại mua sắm màu hồng của web ông */
    .btn-purple-main {
        background-color: #ff79c6;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 30px;
        font-weight: bold;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-purple-main:hover {
            background-color: #e05ca7;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 121, 198, 0.3);
        }

    .text-purple-main {
        color: #ff79c6 !important;
    }
</style>

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item active text-purple-main" aria-current="page">Giới thiệu Web bán sách của tụi mình</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-9 col-md-11">
            <div class="super-intro-card text-center">

                <div class="intro-icon-box">
                    <i class="fa-solid fa-book-open"></i>
                </div>

                <h1 class="fw-bold mb-4 text-dark" style="font-size: 2.3rem;">
                    Giới Thiệu Về <span class="text-purple-main">Website Của Tụi Mình</span>
                </h1>

                <p class="text-secondary mx-auto mb-5" style="max-width: 750px; font-size: 1.15rem; line-height: 1.8; text-align: justify;">
                    Chào mừng bạn đến với hệ thống phân phối tri thức mang tầm vóc vũ trụ của nhóm tụi mình!
                    Được vận hành trên nền tảng công nghệ tối tân bằng tất cả mồ hôi, nước mắt và hàng chục ly trà sữa mang đi,
                    website này sinh ra với sứ mệnh tối thượng là mang những cuốn sách chất lượng nhất đến tận tay bạn.
                    Tụi mình cam kết sách chuẩn chỉnh 100%, giao diện mượt mà và bảo mật tuyệt đối.
                    Nói là "tụi mình" cho đối tác và thầy cô nghe uy tín, sang trang vậy thôi, chứ thực ra từ thiết kế giao diện màu hồng cá tính này,
                    viết code backend C#, cài cắm SQL Server cho đến sửa bug sấp mặt lúc 3 giờ sáng đều do một mình tui gánh team từ đầu tới cuối.
                    Nếu bạn tìm thấy một cuốn sách hay giúp thay đổi cuộc đời, đó là công lao của tác giả; còn nếu hệ thống chạy mượt không một vết xước,
                    đó hoàn toàn là nhờ sự đẹp trai và kiên trì của tui. Chúc bạn có những trải nghiệm mua sắm tuyệt vời và không bị deadline đè bẹp như tui nhé!
                </p>

                <hr class="my-4 text-muted opacity-25">

                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-purple-main shadow-sm">
                        <i class="fa-solid fa-cart-shopping"></i> Ghé trang chủ mua sách ủng hộ tui đi
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>