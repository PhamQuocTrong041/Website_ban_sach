@model Website_ban_sach.Models.Product
@{
    ViewData["Title"] = "Xác nhận xóa sách";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container my-5" style="min-height: 450px;">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-danger shadow-sm rounded-3">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i> Xác Nhận Xóa Sách</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted fs-5">Bạn có chắc chắn muốn xóa cuốn sách này không? Hành động này không thể hoàn tác.</p>
                    
                    <div class="d-flex align-items-start gap-4 p-3 bg-light rounded border mb-4">
                        <img src="@Model.ImageUrl" class="rounded border shadow-sm" style="width: 80px; height: 110px; object-fit: cover;" />
                        <div>
                            <h4 class="fw-bold text-dark mb-1">@Model.Title</h4>
                            <p class="mb-1 text-secondary"><strong>Tác giả:</strong> @Model.Author</p>
                            <p class="mb-1 text-secondary"><strong>Danh mục:</strong> @(Model.Category?.Name ?? "N/A")</p>
                            <p class="mb-0 text-purple-main fw-semibold"><strong>Giá bán:</strong> @Model.Price.ToString("N0")đ</p>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light px-4">Hủy bỏ</a>
                            <button type="submit" class="btn btn-danger px-4 fw-medium">
                                <i class="fa-solid fa-trash me-2"></i> Đồng ý Xóa
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
