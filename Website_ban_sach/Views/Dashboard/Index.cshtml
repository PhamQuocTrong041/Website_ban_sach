@model Website_ban_sach.Models.DashboardStatsViewModel
@{
    ViewData["Title"] = "Dashboard Quản trị";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        background-color: #fff0f7;
        color: #ff79c6;
    }
    .chart-container {
        position: relative;
        height: 300px;
        width: 100%;
    }
</style>

<!-- Welcome Header -->
<div class="mb-4">
    <h3 class="fw-bold text-dark mb-1">Xin chào, Admin! 👋</h3>
    <p class="text-muted small">Dưới đây là tổng quan hoạt động của hệ thống Bookstore.</p>
</div>

<!-- 4 Stats Cards -->
<div class="row g-4 mb-4">
    <!-- Users Card -->
    <div class="col-md-3">
        <div class="card dash-card p-4">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted small fw-medium d-block mb-1">Người dùng</span>
                    <h3 class="fw-bold text-dark m-0">@Model.UserCount</h3>
                    <span class="text-success small fw-semibold"><i class="fa-solid fa-arrow-trend-up"></i> +12.5%</span> <span class="text-muted" style="font-size: 10px;">so với tuần trước</span>
                </div>
                <div class="stat-icon">
                    <i class="fa-solid fa-users"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Orders Card -->
    <div class="col-md-3">
        <div class="card dash-card p-4">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted small fw-medium d-block mb-1">Đơn hàng</span>
                    <h3 class="fw-bold text-dark m-0">@Model.OrderCount</h3>
                    <span class="text-success small fw-semibold"><i class="fa-solid fa-arrow-trend-up"></i> +8.7%</span> <span class="text-muted" style="font-size: 10px;">so với tuần trước</span>
                </div>
                <div class="stat-icon" style="background-color: #fff0f7; color: #ff79c6;">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue Card -->
    <div class="col-md-3">
        <div class="card dash-card p-4">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted small fw-medium d-block mb-1">Doanh thu</span>
                    <h4 class="fw-bold text-dark m-0">@Model.TotalRevenue.ToString("N0")đ</h4>
                    <span class="text-success small fw-semibold"><i class="fa-solid fa-arrow-trend-up"></i> +15.3%</span> <span class="text-muted" style="font-size: 10px;">so với tuần trước</span>
                </div>
                <div class="stat-icon" style="background-color: #fff0f7; color: #ff79c6;">
                    <i class="fa-solid fa-sack-dollar"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Products Card -->
    <div class="col-md-3">
        <div class="card dash-card p-4">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted small fw-medium d-block mb-1">Sản phẩm</span>
                    <h3 class="fw-bold text-dark m-0">@Model.ProductCount</h3>
                    <span class="text-danger small fw-semibold"><i class="fa-solid fa-arrow-trend-down"></i> -3.1%</span> <span class="text-muted" style="font-size: 10px;">so với tuần trước</span>
                </div>
                <div class="stat-icon" style="background-color: #fff0f7; color: #ff79c6;">
                    <i class="fa-solid fa-book"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Grid Charts -->
<div class="row g-4 mb-4">
    <!-- Revenue Chart -->
    <div class="col-lg-8">
        <div class="card dash-card p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold text-dark m-0">Doanh thu</h5>
                <select class="form-select form-select-sm border-0 bg-light w-auto small fw-medium">
                    <option>7 ngày qua</option>
                    <option>30 ngày qua</option>
                </select>
            </div>
            <div class="chart-container">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Status Doughnut Chart -->
    <div class="col-lg-4">
        <div class="card dash-card p-4">
            <h5 class="fw-bold text-dark mb-3">Đơn hàng theo trạng thái</h5>
            <div class="chart-container">
                <canvas id="statusChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Bottom row: Tables -->
<div class="row g-4">
    <!-- Latest Orders Table -->
    <div class="col-lg-7">
        <div class="card dash-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold text-dark m-0">Đơn hàng mới nhất</h5>
                <a asp-action="Orders" class="text-purple-main text-decoration-none small fw-medium">Xem tất cả</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 small">
                    <thead>
                        <tr class="table-light">
                            <th scope="col">Mã đơn</th>
                            <th scope="col">Người nhận</th>
                            <th scope="col" class="text-end">Tổng tiền</th>
                            <th scope="col" class="text-center">Trạng thái</th>
                            <th scope="col">Thời gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.LatestOrders.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">Chưa có đơn hàng nào trong hệ thống.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in Model.LatestOrders)
                            {
                                <tr>
                                    <td class="fw-bold text-dark">#DH@order.Id</td>
                                    <td>@order.ReceiverName</td>
                                    <td class="text-end fw-semibold text-purple-main">@order.TotalAmount.ToString("N0")đ</td>
                                    <td class="text-center">
                                        @if (order.Status == "Chờ xử lý")
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning px-2 py-1 rounded small">@order.Status</span>
                                        }
                                        else if (order.Status == "Đang giao")
                                        {
                                            <span class="badge bg-primary-subtle text-primary border border-primary px-2 py-1 rounded small">@order.Status</span>
                                        }
                                        else if (order.Status == "Đã giao")
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success px-2 py-1 rounded small">@order.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary px-2 py-1 rounded small">@order.Status</span>
                                        }
                                    </td>
                                    <td class="text-muted" style="font-size: 11px;">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Top Selling Products List -->
    <div class="col-lg-5">
        <div class="card dash-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold text-dark m-0">Sản phẩm bán chạy</h5>
                <a asp-controller="ProductManager" asp-action="Index" class="text-purple-main text-decoration-none small fw-medium">Xem tất cả</a>
            </div>
            <div class="d-flex flex-column gap-3">
                @if (!Model.TopSellingProducts.Any())
                {
                    <div class="text-center py-5 text-muted small">Chưa có dữ liệu sản phẩm bán chạy.</div>
                }
                else
                {
                    int index = 1;
                    @foreach (var item in Model.TopSellingProducts)
                    {
                        <div class="d-flex align-items-center gap-3">
                            <span class="fw-bold text-muted" style="width: 20px;">@index.</span>
                            <img src="@(item.Product?.ImageUrl ?? "https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=150")" class="rounded border" style="width: 38px; height: 50px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=150'" />
                            <div class="flex-grow-1 min-w-0">
                                <span class="fw-bold text-dark d-block text-truncate small">@(item.Product?.Title ?? "Sản phẩm không hoạt động")</span>
                                <small class="text-muted">Đã bán: @item.QuantitySold</small>
                            </div>
                            <div class="text-end">
                                <span class="fw-semibold text-purple-main small d-block">@item.TotalRevenue.ToString("N0")đ</span>
                            </div>
                        </div>
                        index++;
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Thư viện vẽ biểu đồ Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            // 1. Vẽ Biểu đồ Doanh thu (Line Chart)
            var revenueCtx = document.getElementById('revenueChart').getContext('2d');
            
            var dailyLabels = @Html.Raw(Json.Serialize(ViewBag.DailyRevenueLabels));
            var dailyValues = @Html.Raw(Json.Serialize(ViewBag.DailyRevenueValues));

            var revenueChart = new Chart(revenueCtx, {
                type: 'line',
                data: {
                    labels: dailyLabels,
                    datasets: [{
                        label: 'Doanh thu ngày (đ)',
                        data: dailyValues,
                        borderColor: '#ff79c6',
                        backgroundColor: 'rgba(255, 121, 198, 0.1)',
                        borderWidth: 3,
                        pointBackgroundColor: '#e05ca7',
                        pointBorderColor: '#ffffff',
                        pointHoverRadius: 6,
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: '#f2edf3'
                            },
                            ticks: {
                                callback: function(value) {
                                    if (value >= 1000000) {
                                        return (value / 1000000) + 'M';
                                    }
                                    if (value >= 1000) {
                                        return (value / 1000) + 'k';
                                    }
                                    return value;
                                },
                                font: {
                                    size: 11
                                }
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                font: {
                                    size: 11
                                }
                            }
                        }
                    }
                }
            });

            // 2. Vẽ Biểu đồ Trạng thái đơn hàng (Doughnut Chart)
            var statusCtx = document.getElementById('statusChart').getContext('2d');
            
            var pending = @Model.PendingCount;
            var shipping = @Model.ShippingCount;
            var delivered = @Model.DeliveredCount;
            var cancelled = @Model.CancelledCount;

            var statusChart = new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Chờ xử lý', 'Đang giao', 'Đã giao', 'Đã hủy'],
                    datasets: [{
                        data: [pending, shipping, delivered, cancelled],
                        backgroundColor: ['#ffc107', '#0d6efd', '#198754', '#dc3545'],
                        borderWidth: 2,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                boxWidth: 12,
                                padding: 15,
                                font: {
                                    size: 11
                                }
                            }
                        }
                    },
                    cutout: '65%'
                }
            });
        });
    </script>
}
