@model IEnumerable<Website_ban_sach.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string currentFilter = ViewBag.StatusFilter ?? string.Empty;
}

<style>
    .order-item-detail {
        background-color: #fdfbfc;
        border: 1px solid #f6eff3;
        border-radius: 8px;
        padding: 12px;
        margin-top: 10px;
    }
</style>

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fa-solid fa-file-invoice-dollar me-2 text-purple-main"></i> Quản Lý Đơn Hàng</h3>
            <p class="text-muted mb-0 small">Xem toàn bộ lịch sử mua hàng, xử lý giao vận và cập nhật trạng thái đơn đặt hàng.</p>
        </div>
    </div>

    <!-- Thông báo kết quả -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Thanh bộ lọc trạng thái -->
    <div class="mb-4 d-flex flex-wrap gap-2">
        <a asp-action="Orders" class="btn btn-sm px-3 py-2 rounded-pill @(string.IsNullOrEmpty(currentFilter) ? "btn-purple" : "btn-outline-secondary")">Tất cả</a>
        <a asp-action="Orders" asp-route-statusFilter="Chờ xử lý" class="btn btn-sm px-3 py-2 rounded-pill @(currentFilter == "Chờ xử lý" ? "btn-warning text-white" : "btn-outline-warning")">Chờ xử lý</a>
        <a asp-action="Orders" asp-route-statusFilter="Đang giao" class="btn btn-sm px-3 py-2 rounded-pill @(currentFilter == "Đang giao" ? "btn-primary" : "btn-outline-primary")">Đang giao</a>
        <a asp-action="Orders" asp-route-statusFilter="Đã giao" class="btn btn-sm px-3 py-2 rounded-pill @(currentFilter == "Đã giao" ? "btn-success" : "btn-outline-success")">Đã giao</a>
        <a asp-action="Orders" asp-route-statusFilter="Đã hủy" class="btn btn-sm px-3 py-2 rounded-pill @(currentFilter == "Đã hủy" ? "btn-danger" : "btn-outline-danger")">Đã hủy</a>
    </div>

    <div class="card dash-card shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark" style="background-color: #21132b;">
                        <tr>
                            <th scope="col" class="py-3 ps-4" style="width: 100px;">Mã đơn</th>
                            <th scope="col" class="py-3">Thông tin người nhận</th>
                            <th scope="col" class="py-3" style="width: 280px;">Sản phẩm đã đặt</th>
                            <th scope="col" class="py-3 text-end" style="width: 130px;">Tổng tiền</th>
                            <th scope="col" class="py-3 text-center" style="width: 150px;">Trạng thái</th>
                            <th scope="col" class="py-3 text-center" style="width: 200px;">Thao tác nhanh</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-folder-open fs-2 d-block mb-3 text-purple-main"></i>
                                    Không tìm thấy đơn đặt hàng nào phù hợp bộ lọc.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">#@order.OrderCode</td>
                                    <td>
                                        <div class="small">
                                            <p class="mb-1"><strong>Họ tên:</strong> @order.ReceiverName</p>
                                            <p class="mb-1"><strong>SĐT:</strong> @order.ReceiverPhone</p>
                                            <p class="mb-0 text-muted text-wrap" style="max-width: 250px;"><strong>Địa chỉ:</strong> @order.ReceiverAddress</p>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column gap-1.5">
                                            @foreach (var item in order.OrderItems)
                                            {
                                                <div class="d-flex align-items-center justify-content-between p-1 bg-light border rounded small" style="font-size: 11px;">
                                                    <span class="text-truncate" style="max-width: 180px;" title="@(item.Product?.Title)">@(item.Product?.Title ?? "N/A")</span>
                                                    <span class="text-secondary fw-medium">x @item.Quantity</span>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-end fw-semibold text-purple-main">@order.TotalAmount.ToString("N0")đ</td>
                                    <td class="text-center">
                                        @if (order.Status == "Chờ xử lý")
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning px-2.5 py-1.5 rounded-pill small">@order.Status</span>
                                        }
                                        else if (order.Status == "Đang giao")
                                        {
                                            <span class="badge bg-primary-subtle text-primary border border-primary px-2.5 py-1.5 rounded-pill small">@order.Status</span>
                                        }
                                        else if (order.Status == "Đã giao")
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success px-2.5 py-1.5 rounded-pill small">@order.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary px-2.5 py-1.5 rounded-pill small">@order.Status</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <!-- Form đổi trạng thái nhanh bằng select box -->
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <select name="status" class="form-select form-select-sm border-purple-main inline-block d-inline w-auto" onchange="this.form.submit()" style="cursor: pointer; font-size: 13px;">
                                                <option value="Chờ xử lý" selected="@(order.Status == "Chờ xử lý")">Chờ xử lý</option>
                                                <option value="Đang giao" selected="@(order.Status == "Đang giao")">Đang giao</option>
                                                <option value="Đã giao" selected="@(order.Status == "Đã giao")">Đã giao</option>
                                                <option value="Đã hủy" selected="@(order.Status == "Đã hủy")">Đã hủy</option>
                                            </select>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
